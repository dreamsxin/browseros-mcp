{
  "manifest_version": 3,
  "name": "Browser Control Agent Panel",
  "version": "0.1.0",
  "description": "A Chrome side panel that talks to a local Python browser agent service.",
  "permissions": ["sidePanel", "storage"],
  "host_permissions": ["http://127.0.0.1/*", "http://localhost/*"],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Browser Control Agent Panel",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
